PORT=3001
NODE_ENV=development

# Postgres (DB dedicada do chat-inunda)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chat_inunda
DB_USER=postgres
DB_PASS=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=30d

# Redis (usado pelo Socket.IO adapter e BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173

# Evolution API (provider padrao)
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=

# Webhook publico do chat_app (Evolution chama aqui)
PUBLIC_WEBHOOK_URL=https://chat.inundaweb.com.br/api/webhooks/evolution
